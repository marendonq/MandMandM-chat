# =============================================================================
# COPIA este archivo a ".env" en esta misma carpeta (backend/).
# El archivo .env no se sube a Git (.gitignore).
# =============================================================================

# OAuth (rellena si usas login Google en local)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Opcional:
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_ID=
# JWT_SECRET=

# Archivos (subida local): tamaño máximo en bytes (10 MB por defecto)
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# PostgreSQL local (Docker Compose en la raíz del repo: docker compose up -d)
# Usuario / contraseña / base de ejemplo: mandmandm (solo desarrollo, no producción)
# Puerto host del compose: 5432 (debe coincidir con docker-compose.yml).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://mandmandm:mandmandm@127.0.0.1:5432/mandmandm

# -----------------------------------------------------------------------------
# MongoDB — conversaciones y mensajes persistentes (feature/message-mongo)
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=groupsapp_messages

# -----------------------------------------------------------------------------
# Redis — presencia y recibos de mensajes
# -----------------------------------------------------------------------------
REDIS_URI=redis://localhost:6379/0
PRESENCE_REDIS_NAMESPACE=presence

# TTL para que `offline_since` siga calculándose tras 3 minutos
PRESENCE_USER_TTL_SECONDS=1800

# TTL para recibos SENT/DELIVERED/READ (para mensajes antiguos)
PRESENCE_RECEIPT_TTL_SECONDS=604800
