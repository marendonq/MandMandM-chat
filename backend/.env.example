# =============================================================================
# COPIA este archivo a ".env" en esta misma carpeta (backend/).
# El archivo .env no se sube a Git (.gitignore).
# =============================================================================

# OAuth (rellena si usas login Google en local)
OAUTH_PUBLIC_BASE_URL=http://127.0.0.1:8000
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Opcional:
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_ID=
# JWT_SECRET=

# Archivos (subida local): tamaño máximo en bytes (10 MB por defecto)
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# PostgreSQL local (Docker Compose en la raíz del repo: docker compose up -d)
# Usuario / contraseña / base de ejemplo: mandmandm (solo desarrollo, no producción)
# Puerto por defecto del compose: 5432. Si mapeas 5433:5432, cambia el puerto aquí.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://mandmandm:mandmandm@127.0.0.1:5432/mandmandm

# Futuro: MongoDB (mensajería), Redis (presencia) — ver docs/postgresql_setup.md
